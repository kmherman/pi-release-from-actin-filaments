RESTART
UNITS LENGTH=A
WHOLEMOLECULES ENTITY0=1-47

PI: CENTER ATOMS=41 #-45
MG: CENTER ATOMS=40
d1: DISTANCE ATOMS=PI,MG

WATER: GROUP ATOMS=48-3695:3,33-35,37-39

MG_cn: COORDINATION GROUPA=MG GROUPB=WATER R_0=3 D_0=0 NN=12

sr: UPPER_WALLS ARG=d1 AT=6.5 KAPPA=1000

METAD ...
LABEL=metad
ARG=d1,MG_cn SIGMA=0.05,0.1 HEIGHT=1 BIASFACTOR=10 TEMP=310.0 PACE=500
GRID_MIN=0,0 GRID_MAX=10,10
CALC_RCT
... METAD

PRINT ARG=d1,MG_cn,metad.bias,metad.rbias,sr.bias STRIDE=100 FILE=COLVAR
