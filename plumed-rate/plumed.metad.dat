RESTART
UNITS LENGTH=A
WHOLEMOLECULES ENTITY0=1-75790

PI: CENTER ATOMS=76395-76399
MG: CENTER ATOMS=76394
d1: DISTANCE ATOMS=PI,MG

METAD ...
LABEL=metad
ARG=d1 SIGMA=0.05 HEIGHT=1 BIASFACTOR=10 TEMP=310.0 PACE=500
GRID_MIN=0 GRID_MAX=5.5
CALC_RCT
ACCELERATION
CALC_MAX_BIAS
... METAD

COMMITTOR ...
ARG=d1
STRIDE=50
BASIN_LL1=4.00
BASIN_UL1=7.0
... COMMITTOR

PRINT ARG=d1,metad.* STRIDE=50 FILE=COLVAR
